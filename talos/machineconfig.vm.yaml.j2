---
# yaml-language-server: $schema=https://raw.githubusercontent.com/siderolabs/talos/refs/heads/release-1.13/website/content/v1.13/schemas/v1alpha1_config.schema.json
# Single-node VM (tuddle) on TrueNAS. Derived from machineconfig.yaml.j2 with
# bare-metal-only bits removed: machine.sysfs (intel_pstate/cpufreq — no driver in
# a guest), machine.udev i915 GPU rule, kubelet /var/mnt/extra bind, and the
# nut-client ExtensionServiceConfig
version: v1alpha1
debug: false
persist: true
machine:
  ca:
    crt: op://Kubernetes/talos/CERTS_OS_CRT
    key: op://Kubernetes/talos/CERTS_OS_KEY
  features:
    diskQuotaSupport: true
    hostDNS:
      enabled: true
      resolveMemberNames: true
      forwardKubeDNSToHost: true # Requires Cilium socketLB features
    kubePrism:
      enabled: true
      port: 7445
    kubernetesTalosAPIAccess:
      enabled: true
      allowedRoles: ["os:admin"]
      allowedKubernetesNamespaces: ["actions-runner-system", "system-upgrade"]
  files:
    # Required for Spegel: https://spegel.dev/docs/getting-started/#talos
    - op: create
      path: /etc/cri/conf.d/20-customization.part
      content: |-
        [plugins."io.containerd.cri.v1.images"]
          discard_unpacked_layers = false
    - op: overwrite
      permissions: 0o644
      path: /etc/nfsmount.conf
      content: |-
        [ NFSMount_Global_Options ]
        nfsvers=4.2
        hard=True
        nconnect=16
        noatime=True
  kubelet:
    defaultRuntimeSeccompProfileEnabled: true
    disableManifestsDirectory: true
    image: ghcr.io/siderolabs/kubelet:{{ ENV.KUBERNETES_VERSION }}
    nodeIP:
      validSubnets: ["10.0.10.0/24"]
  nodeLabels:
    topology.kubernetes.io/zone: controlplane
  sysctls:
    fs.inotify.max_user_watches: 1048576 # Watchdog
    fs.inotify.max_user_instances: 8192 # Watchdog
    net.core.default_qdisc: fq
    net.core.netdev_max_backlog: 50000
    net.core.somaxconn: 65535
    net.core.rmem_max: 67108864 # Cloudflared / QUIC
    net.core.wmem_max: 67108864 # Cloudflared / QUIC
    net.ipv4.neigh.default.gc_thresh1: "4096"
    net.ipv4.neigh.default.gc_thresh2: "8192"
    net.ipv4.neigh.default.gc_thresh3: "16384"
    net.ipv4.ping_group_range: 0 2147483647
    net.ipv4.tcp_congestion_control: bbr
    net.ipv4.tcp_fastopen: 3
    net.ipv4.tcp_fin_timeout: 15
    net.ipv4.tcp_max_syn_backlog: 65535
    net.ipv4.tcp_mtu_probing: 1
    net.ipv4.tcp_notsent_lowat: 131072
    net.ipv4.tcp_slow_start_after_idle: 0
    net.ipv4.tcp_rmem: 4096 87380 33554432
    net.ipv4.tcp_wmem: 4096 65536 33554432
    net.ipv4.tcp_tw_reuse: 1
    net.ipv4.tcp_window_scaling: 1
    sunrpc.tcp_max_slot_table_entries: "128"
    sunrpc.tcp_slot_table_entries: "128"
    user.max_user_namespaces: "11255"
  token: op://Kubernetes/talos/TRUSTDINFO_TOKEN
  type: controlplane
cluster:
  ca:
    crt: op://Kubernetes/talos/CERTS_K8S_CRT
    key: op://Kubernetes/talos/CERTS_K8S_KEY
  clusterName: main
  controlPlane:
    endpoint: https://10.0.10.240:6443
  discovery:
    enabled: false # single node; avoids clashing with the still-running main cluster (shared cluster id)
  extraManifests:
    - # renovate: datasource=github-releases depName=prometheus-operator/prometheus-operator
      https://github.com/prometheus-operator/prometheus-operator/releases/download/v0.86.2/stripped-down-crds.yaml
  id: op://Kubernetes/talos/CLUSTER_ID
  network:
    cni:
      name: none
    dnsDomain: cluster.local
    podSubnets: ["172.30.0.0/16"]
    serviceSubnets: ["172.31.0.0/16"]
  secret: op://Kubernetes/talos/CLUSTER_SECRET
  token: op://Kubernetes/talos/SECRETS_BOOTSTRAPTOKEN
  aggregatorCA:
    crt: op://Kubernetes/talos/CERTS_K8SAGGREGATOR_CRT
    key: op://Kubernetes/talos/CERTS_K8SAGGREGATOR_KEY
  allowSchedulingOnControlPlanes: true
  apiServer:
    image: registry.k8s.io/kube-apiserver:{{ ENV.KUBERNETES_VERSION }}
    certSANs: ["k8s.internal", "10.0.10.240"]
    extraArgs:
      enable-aggregator-routing: true
      feature-gates: MutatingAdmissionPolicy=true
      runtime-config: admissionregistration.k8s.io/v1beta1=true
    auditPolicy:
      apiVersion: audit.k8s.io/v1
      kind: Policy
      rules:
        - level: Metadata
  coreDNS:
    disabled: true
  controllerManager:
    image: registry.k8s.io/kube-controller-manager:{{ ENV.KUBERNETES_VERSION }}
    extraArgs:
      bind-address: 0.0.0.0
  etcd:
    advertisedSubnets: ["10.0.10.0/24"]
    ca:
      crt: op://Kubernetes/talos/CERTS_ETCD_CRT
      key: op://Kubernetes/talos/CERTS_ETCD_KEY
    extraArgs:
      listen-metrics-urls: http://0.0.0.0:2381
      auto-compaction-mode: periodic
      auto-compaction-retention: "1h"
  proxy:
    disabled: true
  secretboxEncryptionSecret: op://Kubernetes/talos/SECRETS_ENCRYPTIONSECRET
  scheduler:
    image: registry.k8s.io/kube-scheduler:{{ ENV.KUBERNETES_VERSION }}
    extraArgs:
      bind-address: 0.0.0.0
    config:
      apiVersion: kubescheduler.config.k8s.io/v1
      kind: KubeSchedulerConfiguration
      profiles:
        - schedulerName: default-scheduler
          plugins:
            score:
              disabled:
                - name: ImageLocality
          pluginConfig:
            - name: PodTopologySpread
              args:
                defaultingType: List
                defaultConstraints:
                  - maxSkew: 1
                    topologyKey: kubernetes.io/hostname
                    whenUnsatisfiable: ScheduleAnyway
  serviceAccount:
    key: op://Kubernetes/talos/CERTS_KUBERNETES_SERVICEACCOUNT_KEY
---
# yaml-language-server: $schema=https://raw.githubusercontent.com/siderolabs/talos/refs/heads/release-1.12/website/content/v1.12/schemas/config.schema.json
apiVersion: v1alpha1
kind: ResolverConfig
nameservers:
  - address: 10.0.10.1
searchDomains:
  disableDefault: true
---
# yaml-language-server: $schema=https://raw.githubusercontent.com/siderolabs/talos/refs/heads/release-1.12/website/content/v1.12/schemas/config.schema.json
apiVersion: v1alpha1
kind: TimeSyncConfig
ntp:
  servers:
    - pool.ntp.org
    - time.cloudflare.com
